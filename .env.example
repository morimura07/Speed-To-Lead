# ─────────────────────────────────────────────────────────────────────────────
# LeadArrow — root environment template.
# Copy to `.env` and adjust. Never commit real secrets.
#   cp .env.example .env
# Per-app overrides can live in apps/<app>/.env.local
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# ── API (apps/api) ───────────────────────────────────────────────────────────
PORT=4000
LOG_LEVEL=info
# Comma-separated list of origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000

# Datastores (match docker-compose.yml credentials)
DATABASE_URL=postgresql://leadarrow:leadarrow@localhost:5432/leadarrow?schema=public
REDIS_URL=redis://localhost:6379

# Public URL of the web dashboard (password-reset links)
APP_URL=http://localhost:3000

# Auth secrets (use strong unique values outside local dev)
JWT_ACCESS_SECRET=dev-access-secret-change-me-please
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Platform admin seed
PLATFORM_ADMIN_EMAIL=admin@leadarrow.local
PLATFORM_ADMIN_PASSWORD=changeme-admin-123
PLATFORM_ADMIN_NAME=LeadArrow Admin

# ── Web (apps/web) ───────────────────────────────────────────────────────────
# Base URL the dashboard uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Provider credentials (added in later phases — left blank for Phase 0) ─────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# STRIPE_SECRET_KEY=
# PUSHOVER_APP_TOKEN=
