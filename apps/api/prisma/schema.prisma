// LeadArrow database schema.
//
// Phase 0 established the multi-tenant spine (organizations, users, events).
// Phase 1 adds authentication, license-key gating, trials, and the platform
// admin who issues keys. Feature tables (reps, leads, integrations, routing
// rules, …) are added in later phases against this foundation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin // company owner
  manager // additional sales manager seats
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

enum LicenseKeyType {
  timed // grants a trial of `trialDays` days
  unlimited // no time limit
}

enum LicenseKeyStatus {
  active // issued, not yet redeemed, usable
  disabled // revoked by an admin; cannot be redeemed
  redeemed // already used to create an organization
}

enum IntegrationType {
  close
  gohighlevel
  salesforce
  hubspot
  slack
  google_calendar
}

enum IntegrationStatus {
  active
  disabled
}

enum LeadStatus {
  received // ingested, awaiting routing
  routing // currently being routed to reps (Phase 3)
  accepted // a rep accepted the lead
  dead_end // exhausted all eligible reps
}

enum RoutingMethod {
  round_robin
  percentage
}

enum RepStatus {
  idle // available to receive a lead
  on_call // currently on a call (ineligible)
  off // manually unavailable
}

enum AttemptOutcome {
  ringing // call placed, awaiting a response
  accepted // rep pressed 1
  declined // rep pressed 2
  timed_out // answered but no key press, or gather timeout
  failed // no answer / busy / call error
}

enum BookingMode {
  triage // call a setter to confirm before the closer takes the call
  closer // alert the assigned closer directly
}

enum BookingAlertStatus {
  pending
  alerted // a rep was rung
  failed // no rep could be resolved/reached
}

enum ReminderStatus {
  scheduled
  rescheduled // moved to a rep's next available block
  completed // the rep was called
  canceled
  failed
}

/// A customer company (tenant). All data is scoped to an organization.
model Organization {
  id                 String             @id @default(cuid())
  name               String
  phone              String?
  smsConsent         Boolean            @default(false)
  smsConsentAt       DateTime?
  trialEndsAt        DateTime?
  subscriptionStatus SubscriptionStatus @default(trialing)

  // Lead routing configuration (Phase 3).
  routingMethod    RoutingMethod @default(round_robin)
  roundRobinCursor Int           @default(0)

  // Availability configuration (Phase 5).
  timezone          String  @default("America/New_York") // IANA tz; rep default
  calendarBusyCheck Boolean @default(false) // skip reps who are calendar-busy

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  events        Event[]
  integrations  Integration[]
  leads         Lead[]
  reps          Rep[]
  attempts      LeadAttempt[]
  bookingAlerts BookingAlert[]
  reminders     FollowUpReminder[]
  redeemedKey   LicenseKey?

  @@map("organizations")
}

/// A person who logs into the dashboard (company owner/admin or sales manager).
model User {
  id           String   @id @default(cuid())
  orgId        String
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(manager)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([orgId])
  @@map("users")
}

/// The SaaS operator. Distinct from org-scoped users; manages license keys and
/// views signup/company statistics from the backend admin surface.
model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("platform_admins")
}

/// Access/license key that gates account creation. Generated by a platform
/// admin, redeemed exactly once by a new organization.
model LicenseKey {
  id        String           @id @default(cuid())
  code      String           @unique
  type      LicenseKeyType
  trialDays Int? // applies to `timed` keys
  status    LicenseKeyStatus @default(active)
  notes     String?

  redeemedByOrgId String?   @unique
  redeemedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redeemedByOrg Organization? @relation(fields: [redeemedByOrgId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("license_keys")
}

/// Hashed, rotatable refresh tokens. Belongs to exactly one subject — either a
/// User or a PlatformAdmin (enforced in application code).
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String?
  adminId   String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user  User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin PlatformAdmin? @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminId])
  @@map("refresh_tokens")
}

/// Single-use, expiring password reset tokens (stored hashed).
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// A connected external system (CRM, Slack, calendar). Each CRM integration
/// exposes a unique inbound webhook (`webhookToken` in the URL) and stores the
/// provider's `signingSecret` so deliveries can be verified.
model Integration {
  id            String            @id @default(cuid())
  orgId         String
  type          IntegrationType
  status        IntegrationStatus @default(active)
  webhookToken  String            @unique
  signingSecret String
  config        Json              @default("{}")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@index([orgId])
  @@map("integrations")
}

/// A normalized prospect that entered the system from a CRM or Slack. The raw
/// provider payload is retained in `raw` for traceability; the typed columns are
/// the canonical, provider-agnostic shape the routing engine consumes.
model Lead {
  id            String     @id @default(cuid())
  orgId         String
  integrationId String?
  source        String // provider key, e.g. "close"
  externalId    String // the record id in the source system
  name          String
  email         String?
  phone         String?
  crmRecordUrl  String?
  status        LeadStatus @default(received)
  acceptedById  String? // rep who accepted (Phase 3)
  raw           Json       @default("{}")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integration  Integration?  @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  acceptedBy   Rep?          @relation("AcceptedLeads", fields: [acceptedById], references: [id], onDelete: SetNull)
  attempts     LeadAttempt[]

  // Idempotency: a given source record maps to exactly one lead per org, so
  // webhook retries don't create duplicates.
  @@unique([orgId, source, externalId])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@map("leads")
}

/// A sales rep who can be rung when a lead arrives. Phase 3 keeps this minimal
/// (name + phone + availability flags); full availability windows, days off, and
/// calendar checks arrive in Phase 5.
model Rep {
  id             String    @id @default(cuid())
  orgId          String
  name           String
  phone          String
  active         Boolean   @default(true)
  status         RepStatus @default(idle)
  routingPercent Int? // weight for percentage routing (0–100)
  order          Int       @default(0) // tiebreak ordering for round-robin

  // Availability (Phase 5). `availability` is a weekly schedule keyed by weekday
  // 0–6 → [{ start, end }] in "HH:MM"; an empty object means "always available".
  // `daysOff` is a list of "YYYY-MM-DD" dates. `timezone` overrides the org default.
  timezone      String? // IANA tz; falls back to the org timezone
  calendarEmail String? // calendar whose free/busy to check (Google, when enabled)
  availability  Json    @default("{}")
  daysOff       Json    @default("[]")

  // Realtime softphone + push (Phase 4).
  pairingToken    String? @unique // links a paired Chrome extension to this rep
  pushoverUserKey String? // optional Pushover user/group key for emergency alerts

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  attempts      LeadAttempt[]
  acceptedLeads Lead[]             @relation("AcceptedLeads")
  bookingAlerts BookingAlert[]
  reminders     FollowUpReminder[]

  @@index([orgId])
  @@map("reps")
}

/// An appointment posted in Slack that the system alerts a rep about — either a
/// setter to confirm (triage) or the assigned closer (closer mode).
model BookingAlert {
  id        String             @id @default(cuid())
  orgId     String
  mode      BookingMode
  title     String
  hostEmail String?
  repId     String?
  status    BookingAlertStatus @default(pending)
  raw       Json               @default("{}")
  createdAt DateTime           @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rep          Rep?         @relation(fields: [repId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@map("booking_alerts")
}

/// A scheduled call reminding a rep of a CRM follow-up task at a given time.
/// If the rep is unavailable at `dueAt`, it's moved to their next free block.
model FollowUpReminder {
  id        String         @id @default(cuid())
  orgId     String
  repId     String
  crmTaskId String?
  note      String
  dueAt     DateTime
  status    ReminderStatus @default(scheduled)
  attempts  Int            @default(0)
  createdAt DateTime       @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rep          Rep          @relation(fields: [repId], references: [id], onDelete: Cascade)

  @@index([orgId, dueAt])
  @@map("followup_reminders")
}

/// One ring of one rep for one lead. The routing state machine transitions an
/// attempt's `outcome` exactly once (atomically), which is the core idempotency
/// guard against duplicate telephony webhooks.
model LeadAttempt {
  id             String         @id @default(cuid())
  orgId          String
  leadId         String
  repId          String
  channel        String         @default("phone")
  providerCallId String? // e.g. Twilio Call SID
  outcome        AttemptOutcome @default(ringing)
  answeredAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  rep          Rep          @relation(fields: [repId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([providerCallId])
  @@map("lead_attempts")
}

/// Append-only event store — the analytics backbone. One row per meaningful
/// state transition (lead.received, alert.sent, lead.accepted, …). `type`
/// values come from the shared EventType catalog; `payload` holds the
/// event-specific data as JSON.
model Event {
  id         String   @id @default(cuid())
  orgId      String
  type       String
  leadId     String?
  repId      String?
  payload    Json     @default("{}")
  occurredAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, occurredAt])
  @@index([orgId, type, occurredAt])
  @@index([leadId])
  @@map("events")
}
