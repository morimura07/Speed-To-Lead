# API-local environment template (apps/api).
# Prisma reads this file. Copy to `.env` for local development:
#   cp apps/api/.env.example apps/api/.env

NODE_ENV=development
PORT=4000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql://leadarrow:leadarrow@localhost:5432/leadarrow?schema=public
REDIS_URL=redis://localhost:6379

# Public URL of the web dashboard (used in password-reset links).
APP_URL=http://localhost:3000

# Email (optional) — SMTP for password resets, license keys, billing emails.
# Leave SMTP_HOST blank to log emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=LeadArrow <noreply@leadarrow.local>

# Public URL of this API (used to build inbound CRM webhook URLs).
API_PUBLIC_URL=http://localhost:4000

# Auth — generate strong, unique secrets for any non-local environment:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=dev-access-secret-change-me-please
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Platform admin (seeded via `pnpm --filter @leadarrow/api db:seed`)
PLATFORM_ADMIN_EMAIL=admin@leadarrow.local
PLATFORM_ADMIN_PASSWORD=changeme-admin-123
PLATFORM_ADMIN_NAME=LeadArrow Admin

# Telephony (Twilio). Leave blank locally — calls/SMS no-op until configured.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE_SIGNATURE=true
RING_TIMEOUT_SECONDS=25

# Pushover (optional emergency push). App token from https://pushover.net.
PUSHOVER_APP_TOKEN=

# Slack (optional) — for booking alerts + Slack lead source. From your Slack app.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Billing (optional) — Stripe. STRIPE_PRICE_ID is the recurring subscription price.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Routing worker (consumes the lead-routing queue; needs Redis). Set false to disable.
ROUTING_WORKER_ENABLED=true

# Error tracking (optional) — Sentry DSN. Blank = disabled.
SENTRY_DSN=
