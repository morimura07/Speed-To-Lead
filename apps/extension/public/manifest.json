{
  "manifest_version": 3,
  "name": "LeadArrow Softphone",
  "version": "0.0.0",
  "description": "Lightweight softphone — rings the right rep the instant a lead lands.",
  "action": {
    "default_title": "LeadArrow",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": ["storage", "notifications"],
  "host_permissions": ["http://localhost:4000/*"]
}
